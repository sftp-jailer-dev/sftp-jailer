.TH "SFTP-JAILER" "1" "Apr 2026" "sftp-jailer 1" "User Commands"

.SH NAME
sftp-jailer-observe-run - Ingest sshd events from journald into the observation DB


.SH SYNOPSIS
\fBsftp-jailer observe-run [flags]\fP


.SH DESCRIPTION
observe-run drains new sshd events from the journal cursor file,
classifies them into the four-tier model, batched-INSERTs them into the
SQLite observations table, and runs end-of-run compaction + size-cap pruning.

.PP
Emits NDJSON progress events on stdout (per phase) and a final 'done' event
with the run summary. Use --quiet to suppress everything except 'done'.

.PP
Exit codes:
  0  success (or skipped: another run in progress)
  1  generic failure
  2  schema drift (DB written by a newer binary)


.SH OPTIONS
\fB--config\fP="/etc/sftp-jailer/config.yaml"
	settings file path

.PP
\fB--cursor\fP="/var/lib/sftp-jailer/observer.cursor"
	journalctl cursor file path

.PP
\fB--db\fP="/var/lib/sftp-jailer/observations.db"
	SQLite DB path

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for observe-run

.PP
\fB--quiet\fP[=false]
	suppress per-line JSON; emit only the final summary line

.PP
\fB--since\fP=""
	test-only: override the time window (e.g. '7 days ago')


.SH SEE ALSO
\fBsftp-jailer(1)\fP


